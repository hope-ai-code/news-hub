# Flask session secret - set to a random string for persistent sessions
# SECRET_KEY=change-me-to-a-random-string

# Database URL (default: SQLite in ./data/)
# DATABASE_URL=sqlite:////app/data/news_hub.db

# Port the app listens on (default: 5000)
# PORT=5000

# Timezone for scheduled deliveries (default: UTC)
TZ=Europe/Oslo
